generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                  @id @default(autoincrement())
  name                  String
  email                 String               @unique
  passwordHash          String
  createdAt             DateTime             @default(now())
  ownedGroups           Group[]
  memberships           GroupMember[]
  paidExpenses          Expense[]
  expenseParticipations ExpenseParticipant[]
  paidSettlements       Settlement[]         @relation("PaidSettlements")
  receivedSettlements   Settlement[]         @relation("ReceivedSettlements")
  uploadedSessions      ImportSession[]      @relation("UploadedSessions")
  reviewedAnomalies     ImportAnomaly[]      @relation("ReviewedAnomalies")
}

model Group {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  owner       User          @relation(fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id       Int       @id @default(autoincrement())
  groupId  Int
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   Int
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@index([groupId])
  @@index([userId])
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

model Expense {
  id              Int                  @id @default(autoincrement())
  groupId         Int
  group           Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  amount          Decimal              @db.Decimal(10, 2)
  currency        String
  exchangeRate    Decimal?             @db.Decimal(12, 6)
  convertedAmount Decimal?             @db.Decimal(10, 2)
  expenseDate     DateTime
  paidById        Int
  paidBy          User                 @relation(fields: [paidById], references: [id], onDelete: Cascade)
  splitType       SplitType            @default(EQUAL)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  participants    ExpenseParticipant[]

  @@index([groupId])
  @@index([paidById])
}

model ExpenseParticipant {
  id              Int      @id @default(autoincrement())
  expenseId       Int
  expense         Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareAmount     Decimal? @db.Decimal(10, 2)
  sharePercentage Decimal? @db.Decimal(5, 2)

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id              Int      @id @default(autoincrement())
  groupId         Int
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payerId         Int
  payer           User     @relation("PaidSettlements", fields: [payerId], references: [id], onDelete: Cascade)
  receiverId      Int
  receiver        User     @relation("ReceivedSettlements", fields: [receiverId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(10, 2)
  currency        String
  exchangeRate    Decimal? @db.Decimal(12, 6)
  convertedAmount Decimal? @db.Decimal(10, 2)
  settlementDate  DateTime
  notes           String?
  createdAt       DateTime @default(now())

  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
}

enum ImportSessionStatus {
  PENDING
  PROCESSING
  REVIEW_REQUIRED
  COMPLETED
  FAILED
}

enum ImportRecordStatus {
  PENDING
  VALID
  INVALID
  REVIEW_REQUIRED
}

model ImportSession {
  id               Int                 @id @default(autoincrement())
  uploadedById     Int
  uploadedBy       User                @relation("UploadedSessions", fields: [uploadedById], references: [id], onDelete: Cascade)
  originalFileName String
  status           ImportSessionStatus @default(PENDING)
  totalRows        Int                 @default(0)
  createdAt        DateTime            @default(now())
  records          ImportRecord[]
  anomalies        ImportAnomaly[]

  @@index([uploadedById])
}

model ImportRecord {
  id              Int                @id @default(autoincrement())
  importSessionId Int
  importSession   ImportSession      @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  rowNumber       Int
  rawData         Json
  status          ImportRecordStatus @default(PENDING)
  anomalies       ImportAnomaly[]

  @@index([importSessionId])
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  OPEN
  APPROVED
  REJECTED
  FIXED
}

model ImportAnomaly {
  id              Int                @id @default(autoincrement())
  importSessionId Int
  importSession   ImportSession      @relation(fields: [importSessionId], references: [id])
  importRecordId  Int
  importRecord    ImportRecord       @relation(fields: [importRecordId], references: [id])
  anomalyType     String             @db.VarChar(100)
  severity        AnomalySeverity    @default(MEDIUM)
  description     String             @db.VarChar(500)
  suggestedAction String?            @db.VarChar(500)
  status          AnomalyStatus      @default(OPEN)
  reviewDecision  AnomalyDecision    @default(PENDING)
  reviewedById    Int?
  reviewedBy      User?              @relation("ReviewedAnomalies", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  resolutionNotes String?            @db.VarChar(500)
  createdAt       DateTime           @default(now())
  resolutions     ImportResolution[]

  @@index([importSessionId])
  @@index([importRecordId])
  @@index([status])
  @@index([severity])
  @@index([reviewDecision])
  @@index([reviewedById])
}

enum AnomalyDecision {
  PENDING
  APPROVED
  REJECTED
  MANUAL_FIX
  MERGED
}

enum ResolutionType {
  APPROVED
  REJECTED
  MERGED
  CONVERT_TO_SETTLEMENT
  CONVERT_TO_REFUND
  MANUAL_CORRECTION
}

model ImportResolution {
  id             Int            @id @default(autoincrement())
  anomalyId      Int
  anomaly        ImportAnomaly  @relation(fields: [anomalyId], references: [id], onDelete: Cascade)
  resolutionType ResolutionType
  originalValue  Json?
  resolvedValue  Json?
  createdAt      DateTime       @default(now())

  @@index([anomalyId])
}
